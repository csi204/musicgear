// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "workerd"
}

datasource db {
  provider = "postgresql"
}

model DailySalesReport {
  id           String   @id @default(uuid()) @db.Uuid
  reportDate   DateTime @unique @db.Date
  totalOrders  Int      @default(0)
  totalRevenue Decimal  @default(0.00) @db.Decimal(10,2)
  updatedAt    DateTime @default(now()) @updatedAt
}

model InventorySnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @unique @db.Uuid
  productName  String
  category     String   @default("Uncategorized")
  stockLevel   Int      @default(0)
  reorderPoint Int      @default(0)
  status       String   // "In Stock", "Low", "Critical"
  updatedAt    DateTime @default(now()) @updatedAt
}

model SystemAuditLog {
  logId       String   @id @default(uuid()) @db.Uuid
  eventType   String   // เช่น "order_created", "inventory_adjusted"
  referenceId String   @db.Uuid // ID ของ Order หรือ Product
  payload     Json     // เก็บข้อมูลดิบที่ได้จาก QStash เผื่อใช้วิเคราะห์ย้อนหลัง
  createdAt   DateTime @default(now())
}

model ProductSalesSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  reportDate   DateTime @db.Date
  productId    String   @db.Uuid
  productName  String
  category     String
  quantitySold Int      @default(0)
  revenue      Decimal  @default(0.00) @db.Decimal(10,2)
  updatedAt    DateTime @default(now()) @updatedAt
  @@unique([reportDate, productId])
}