// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "workerd"
}

datasource db {
  provider = "postgresql"
}

enum InventoryAction {
  receive
  adjust
  reserve
  release
  sale_deduct
}

model Inventory {
  inventoryId      String   @id @default(uuid()) @db.Uuid
  productId        String   @unique @db.Uuid // Soft ref -> product-svc
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0)
  reorderPoint     Int      @default(0)     // จุด reorder สำหรับแจ้งเตือน Low/Critical
  updatedAt        DateTime @default(now()) @updatedAt @db.Timestamptz
}

model InventoryLog {
  id         String          @id @default(uuid()) @db.Uuid
  productId  String          @db.Uuid // Soft ref -> product-svc
  orderId    String?         @db.Uuid  // Soft ref -> order-svc (à¹ƒà¸Šà¹‰à¸•à¸­à¸™ reserve/release/sale_deduct)
  beforeQty  Int
  afterQty   Int
  changeQty  Int
  action     InventoryAction
  staffId    String?         @db.Uuid // Soft ref -> user-svc
  createdAt  DateTime        @default(now()) @db.Timestamptz

  @@index([productId])
  @@index([orderId])
  @@index([staffId])
  @@index([createdAt])
}