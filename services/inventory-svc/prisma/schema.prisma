// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InventoryAction {
  receive
  adjust
  reserve
  release
  sale_deduct

  @@map("inventory_action")
}

model Inventory {
  inventoryId      String   @id @default(uuid()) @map("inventory_id") @db.Uuid
  productId        String   @unique @map("product_id") @db.Uuid // Soft ref -> product-svc
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0) @map("reserved_quantity")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("inventory")
}

model InventoryLog {
  id         String          @id @default(uuid()) @db.Uuid
  productId  String          @map("product_id") @db.Uuid // Soft ref -> product-svc
  beforeQty  Int             @map("before_qty")
  afterQty   Int             @map("after_qty")
  changeQty  Int             @map("change_qty")
  action     InventoryAction
  staffId    String?         @map("staff_id") @db.Uuid // Soft ref -> user-svc
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz

  @@map("inventory_logs")
  @@index([productId], map: "idx_inventory_logs_product_id")
  @@index([staffId], map: "idx_inventory_logs_staff_id")
  @@index([createdAt], map: "idx_inventory_logs_created_at")
}