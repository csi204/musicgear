generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Cart {
  cartId     String   @id @default(uuid()) @db.Uuid
  customerId String? // Soft ref to user-svc (string Kinde ID)
  sessionId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  items CartItem[]
}

model CartItem {
  cartItemId String  @id @default(uuid()) @db.Uuid
  cartId     String  @db.Uuid
  productId  String  @db.Uuid // Soft ref to product-svc
  quantity   Int
  price      Decimal @db.Decimal(10, 2)
  color      String?
  title      String?
  imageUrl   String?
  brand      String?

  cart Cart @relation(fields: [cartId], references: [cartId])
}
