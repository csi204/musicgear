{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "concurrency": "20",
  "globalEnv": ["NODE_ENV", "NEXTAUTH_SECRET"],
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": { "outputs": ["dist/**", ".next/**"] },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": ["CLOUDFLARE_API_TOKEN", "CLOUDFLARE_ACCOUNT_ID"]
    },
    "lint": {}
  }
}